import os, cv2, gc, torch, time, random
import numpy as np
import matplotlib.pyplot as plt
from tqdm.auto import tqdm
from torch.amp import GradScaler, autocast 
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import DataLoader, Dataset
import albumentations as A
from albumentations.pytorch import ToTensorV2
import torch.nn.functional as F


gc.collect()
torch.cuda.empty_cache()


def seed_manual(seed=42):
    random.seed(seed)
    os.environ['PYTHONHASHSEED'] = str(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed(seed)
    torch.backends.cudnn.deterministic = True
    torch.backends.cudnn.benchmark = False


seed_manual(42)


#Hyperparameters
DATA_DIR = "/kaggle/input/spectrogram"
TRAIN_IMG_DIR = "/kaggle/input/spectrogram/trainSet/input"
TRAIN_MASK_DIR = "/kaggle/input/spectrogram/trainSet/label"
TEST_IMG_DIR = "/kaggle/input/spectrogram/testSet/input"
TEST_MASK_DIR = "/kaggle/input/spectrogram/testSet/label"

DEVICE = "cuda" if torch.cuda.is_available() else "cpu"
BATCH_SIZE = 32 
LEARNING_RATE = 1e-4
NUM_EPOCHS = 60


def discover_colors(path):
    unique_colors = set()
    all_files = os.listdir(path)
    print(f"🔍 Scaning {len(all_files)} for labeling")
    for f in tqdm(all_files):
        m = cv2.imread(os.path.join(path, f))
        if m is None: continue
        m = cv2.cvtColor(m, cv2.COLOR_BGR2RGB)
        colors = np.unique(m.reshape(-1, 3), axis=0)
        for c in colors: unique_colors.add(tuple(c))
            
    sorted_colors = sorted(list(unique_colors))
    color_to_idx = {color: i for i, color in enumerate(sorted_colors)}
    idx_to_color = {i: color for i, color in enumerate(sorted_colors)}
    return color_to_idx, idx_to_color


COLOR_MAP, REV_COLOR_MAP = discover_colors(TRAIN_MASK_DIR)
NUM_CLASSES = len(COLOR_MAP)
print(f"There are {NUM_CLASSES} classes are there in the train dataset.")


class LTENRDataset(Dataset):
    def __init__(self, img_dir, mask_dir, color_map, transform=None):
        self.img_dir, self.mask_dir = img_dir, mask_dir
        self.color_map, self.transform = color_map, transform
        self.images = sorted(os.listdir(img_dir))

    def __len__(self): return len(self.images)

    def __getitem__(self, idx):
        img = cv2.imread(os.path.join(self.img_dir, self.images[idx]))
        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
        mask_rgb = cv2.imread(os.path.join(self.mask_dir, self.images[idx]))
        mask_rgb = cv2.cvtColor(mask_rgb, cv2.COLOR_BGR2RGB)

        h, w = mask_rgb.shape[:2]
        mask_idx = np.zeros((h, w), dtype=np.int64)
        for color, c_idx in self.color_map.items():
            mask_idx[np.all(mask_rgb == np.array(color), axis=-1)] = c_idx

        if self.transform:
            aug = self.transform(image=img, mask=mask_idx)
            img, mask_idx = aug['image'], aug['mask']
        return img, mask_idx


train_tr = A.Compose([
    A.HorizontalFlip(p=0.5),
    A.RandomBrightnessContrast(p=0.2),
    A.GaussNoise(std_range=(0.02, 0.05), p=0.2),
    A.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]),
    ToTensorV2()
])

test_tr = A.Compose([
    A.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]),
    ToTensorV2()
])
train_loader = DataLoader(
    LTENRDataset(TRAIN_IMG_DIR, TRAIN_MASK_DIR, COLOR_MAP, train_tr), 
    batch_size=BATCH_SIZE, 
    shuffle=True, 
    num_workers=4,          
    pin_memory=True, 
    prefetch_factor=2,      
    persistent_workers=True 
)
test_loader = DataLoader(LTENRDataset(TEST_IMG_DIR, TEST_MASK_DIR, COLOR_MAP, test_tr), 
                         batch_size=BATCH_SIZE, shuffle=False, num_workers=2)


class DoubleConv(nn.Module):
    def __init__(self, in_channels, out_channels):
        super().__init__()
        self.conv = nn.Sequential(
            nn.Conv2d(in_channels, out_channels, 3, 1, 1, bias=False),
            nn.BatchNorm2d(out_channels),
            nn.ReLU(inplace=True),
            nn.Conv2d(out_channels, out_channels, 3, 1, 1, bias=False),
            nn.BatchNorm2d(out_channels),
            nn.ReLU(inplace=True)
        )
    def forward(self, x): return self.conv(x)

class UNet(nn.Module):
    def __init__(self, in_channels=3, out_channels=3):
        super().__init__()
        self.downs = nn.ModuleList()
        self.ups = nn.ModuleList()
        self.pool = nn.MaxPool2d(2)
        features = [64, 128, 256, 512]

        for f in features:
            self.downs.append(DoubleConv(in_channels, f))
            in_channels = f
        
        for f in reversed(features):
            self.ups.append(nn.ConvTranspose2d(f*2, f, 2, 2))
            self.ups.append(DoubleConv(f*2, f))
            
        self.bottleneck = DoubleConv(features[-1], features[-1]*2)
        self.final_conv = nn.Conv2d(features[0], out_channels, 1)

    def forward(self, x):
        skips = []
        for down in self.downs:
            x = down(x)
            skips.append(x)
            x = self.pool(x)
        x = self.bottleneck(x)
        skips = skips[::-1]
        for i in range(0, len(self.ups), 2):
            x = self.ups[i](x)
            skip = skips[i//2]
            x = self.ups[i+1](torch.cat((skip, x), dim=1))
        return self.final_conv(x)


model = UNet(in_channels=3, out_channels=NUM_CLASSES).to(DEVICE)

if hasattr(torch, 'compile'):
    model = torch.compile(model)

optimizer = optim.Adam(model.parameters(), lr=LEARNING_RATE)
loss_fn = nn.CrossEntropyLoss() # Yêu cầu nhãn là LongTensor
scaler = GradScaler(device=DEVICE)

history = {"train_loss": [], "test_miou": []}
best_miou = 0.0

print(f"Start {DEVICE}...")
start_time_total = time.time()

# Train loop
for epoch in range(NUM_EPOCHS):
    epoch_start_time = time.time()
    model.train()
    epoch_loss = 0
    
    # Progress bar
    progress_bar = tqdm(enumerate(train_loader), total=len(train_loader), desc=f"Epoch {epoch+1}/{NUM_EPOCHS}")
    
    for batch_idx, (x, y) in progress_bar:
        x = x.to(DEVICE)
        # Ép kiểu 
        y = y.to(DEVICE).long() 
        
        with autocast(device_type='cuda'):
            logits = model(x)
            loss = loss_fn(logits, y)
        
        optimizer.zero_grad(set_to_none=True)
        scaler.scale(loss).backward()
        scaler.step(optimizer)
        scaler.update()
        
        epoch_loss += loss.item()
        
        current_rate = progress_bar.format_dict['rate']
        speed_text = f"{current_rate:.2f} it/s" if current_rate else "Calculating..."
        progress_bar.set_postfix({"Loss": f"{loss.item():.4f}", "Speed": speed_text})

    # Evaluation 
    avg_train_loss = epoch_loss / len(train_loader)
    model.eval()
    total_iou = 0
    
    with torch.no_grad():
        with autocast(device_type='cuda'):
            for x_test, y_test in test_loader:
                x_test = x_test.to(DEVICE)
                y_test = y_test.to(DEVICE).long()
                
                preds = torch.argmax(model(x_test), dim=1)
                
                # Tính toán mIoU cho dữ liệu đa nhãn
                inter = (preds & y_test).float().sum()
                union = (preds | y_test).float().sum()
                total_iou += (inter + 1e-7) / (union + 1e-7)
    
    current_miou = (total_iou / len(test_loader)).item()
    epoch_duration = time.time() - epoch_start_time
    
    history["train_loss"].append(avg_train_loss)
    history["test_miou"].append(current_miou)
    
    print(f"✅ Epoch {epoch+1} | Time: {epoch_duration:.1f}s | Loss: {avg_train_loss:.4f} | mIoU: {current_miou:.4f}")

    if current_miou > best_miou:
        best_miou = current_miou
        torch.save(model.state_dict(), "Best_UnetLTE.pth")
        print(f"Save best model (mIoU: {best_miou:.4f})")

total_duration = (time.time() - start_time_total) / 60
print(f"\n Total time:  {total_duration:.2f} minutes")


import torch
import numpy as np
import matplotlib.pyplot as plt
import random

def plot_results(model, dataset, device, color_map_rev, idx=None):
    model.eval()

    if idx is None:
        idx = random.randint(0, len(dataset) - 1)
    img, mask = dataset[idx] 
    with torch.no_grad():
        with torch.amp.autocast(device_type='cuda' if 'cuda' in device else 'cpu'):
            # Thêm batch dimension (1, C, H, W) và đưa lên device
            input_tensor = img.unsqueeze(0).to(device)
            logits = model(input_tensor)
            pred = torch.argmax(logits, dim=1).squeeze().cpu().numpy()
    target = mask.numpy()
    num_classes = len(color_map_rev)
#miou
    ious = []
    for cls in range(num_classes):
        intersection = np.logical_and(pred == cls, target == cls).sum()
        union = np.logical_or(pred == cls, target == cls).sum()
        
        if union == 0:
            continue 
        ious.append(intersection / (union + 1e-7))
    miou_single = np.mean(ious) if ious else 0.0
    def to_color(m):
        h, w = m.shape
        rgb = np.zeros((h, w, 3), dtype=np.uint8)
        for i, color in color_map_rev.items():
            rgb[m == i] = [int(c) for c in color]
        return rgb

    plt.figure(figsize=(18, 6))
    plt.subplot(1, 3, 1)
    img_display = img.permute(1, 2, 0).cpu().numpy()
    mean = np.array([0.485, 0.456, 0.406])
    std = np.array([0.229, 0.224, 0.225])
    img_display = std * img_display + mean
    img_display = np.clip(img_display, 0, 1) # Đảm bảo giá trị trong khoảng [0, 1]
    plt.imshow(img_display)
    plt.title(f"Spectrogram (Index: {idx})")
    plt.axis("off")
    plt.subplot(1, 3, 2)
    plt.imshow(to_color(pred))
    plt.title(f"Predicted Mask (mIoU: {miou_single:.4f})")
    plt.axis("off")
    plt.subplot(1, 3, 3)
    plt.imshow(to_color(target))
    plt.title("Ground Truth")
    plt.axis("off")

    plt.tight_layout()
    plt.show()


plot_results(model, test_loader.dataset, DEVICE, REV_COLOR_MAP, 27)


